generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       String  @id @default(uuid())
  username String  @unique
  password String
  orders   Order[]
}

model Stock {
  id     String  @id @default(uuid())
  title  String
  symbol String
  orders Order[]
  fills  Fill[]
}

model Order {
  id        String      @id @default(uuid())
  userId    String
  side      OrderSide   @default(BUY)
  type      OrderType   @default(LIMIT)
  stockId   String
  price     Int
  qty       Int
  filledQty Int
  status    OrderStatus @default(FILLED)
  stock     Stock       @relation(fields: [stockId], references: [id])
  user      User        @relation(fields: [userId], references: [id])
  buyfills  Fill[]      @relation("BuyOrder")
  sellFills Fill[]      @relation("SellOrder")
}

model Fill {
  id          String @id @default(uuid())
  stockId     String
  price       Int
  qty         Int
  buyOrderId  String
  sellOrderId String
  stock       Stock  @relation(fields: [stockId], references: [id])
  buyOrder    Order  @relation("BuyOrder", fields: [buyOrderId], references: [id])
  sellOrder   Order  @relation("SellOrder", fields: [sellOrderId], references: [id])
}

enum OrderSide {
  BUY
  SELL
}

enum OrderType {
  LIMIT
  MARKET
}

enum OrderStatus {
  FILLED
  CANCELLED
}
