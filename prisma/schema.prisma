

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}


model User{
  id            Int         @default(autoincrement()) @id 
  username      String      @unique
  password      String
  orders        Order[]
}

model Stock {
  id            Int         @default(autoincrement()) @id
  title         String
  symbol        String    
  orders        Order[]
  fills         Fill[]
}

model Order{
  id            Int         @default(autoincrement()) @id
  userId        Int
  side          OrderSide   @default(BUY)
  type          OrderType   @default(LIMIT)
  stockId       Int
  price         Int
  qty           Int
  filledQty     Int
  status        OrderStatus @default(FILLED)
  stock         Stock       @relation(fields: [stockId],references: [id])
  user          User        @relation(fields: [userId],references: [id])
  buyfills      Fill[]      @relation("BuyOrder")
  sellFills     Fill[]      @relation("SellOrder")
}

model Fill{
  id            Int         @default(autoincrement()) @id
  stockId       Int
  price         Int
  qty           Int
  buyOrderId    Int
  sellOrderId   Int
  stock         Stock       @relation(fields: [stockId],references: [id])
  buyOrder      Order       @relation("BuyOrder",fields: [buyOrderId],references: [id])
  sellOrder     Order       @relation("SellOrder",fields: [sellOrderId],references: [id])
  
}


enum OrderSide{
  BUY
  SELL
}

enum OrderType{
  LIMIT
  MARKET
}

enum OrderStatus{
  FILLED
  CANCELLED
}